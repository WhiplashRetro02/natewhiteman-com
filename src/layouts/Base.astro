---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Nate Whiteman — Data & AI Leadership',
  description = 'Data Scientist & AI Engineer specializing in agentic systems, knowledge graphs, and the infrastructure that makes AI operationally useful.',
  ogImage = '/og-image.png',
} = Astro.props;

const plausibleUrl = import.meta.env.PUBLIC_PLAUSIBLE_URL ?? '';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700;800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;500&family=Libre+Franklin:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Social / OG -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- GEO: Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Nathaniel Whiteman",
    "alternateName": "Nate Whiteman",
    "jobTitle": "Data Scientist & AI Engineer",
    "description": "Data & AI Leader specializing in agentic systems, knowledge graphs, and AI enablement strategy.",
    "url": "https://natewhiteman.com",
    "sameAs": [
      "https://linkedin.com/in/nathaniel-whiteman",
      "https://github.com/YOUR_GITHUB_HANDLE"
    ],
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "University of California, Los Angeles"
    },
    "knowsAbout": [
      "Artificial Intelligence",
      "Knowledge Graphs",
      "Retrieval-Augmented Generation",
      "Neo4j",
      "Agentic AI Systems",
      "Model Context Protocol",
      "Data Architecture",
      "Cognitive Science"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "CGI"
    }
  })} />

  <!-- Styles injected by Astro via frontmatter import -->

  <!-- Plausible Analytics (self-hosted) -->
  {plausibleUrl && (
    <script
      defer
      data-domain="natewhiteman.com"
      src={`${plausibleUrl}/js/script.js`}
    />
  )}
</head>
<body>
  <!-- Ambient background layers -->
  <div class="ambient-layer"></div>
  <div class="noise-overlay"></div>
  <div class="graph-net" aria-hidden="true">
    <div class="graph-node"></div>
    <div class="graph-node"></div>
    <div class="graph-node"></div>
    <div class="graph-node"></div>
    <div class="graph-node"></div>
    <div class="graph-node"></div>
    <div class="graph-node"></div>
    <div class="graph-node"></div>
  </div>

  <!-- Navigation -->
  <nav class="site-nav" id="site-nav">
    <a href="/" class="nav-wordmark">nate<span class="wm-accent">whiteman</span>.com</a>
    <ul class="nav-links">
      <li><a href="/#about">About</a></li>
      <li><a href="/#systems">Systems</a></li>
      <li><a href="/#projects">Projects</a></li>
      <li><a href="/#writing">Thinking Out Loud</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/annabeth" class="nav-current-project">Current Project</a></li>
      <li><a href="/services#inquiry" class="nav-cta">Work with me &rarr;</a></li>
    </ul>
  </nav>

  <!-- Page Content -->
  <main class="page-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer container">
    <span class="footer-text">&copy; {new Date().getFullYear()} Nathaniel Whiteman</span>
    <span class="footer-trail">
      Cognitive Science &rarr; Data &rarr; AI &rarr; <span class="accent">Leadership</span>
    </span>
  </footer>

  <!-- Identity Pixel -->
  <script is:inline>
    (function() {
      function uuid() {
        return (typeof crypto !== 'undefined' && crypto.randomUUID)
          ? crypto.randomUUID()
          : 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
              var r = Math.random() * 16 | 0;
              return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
            });
      }

      // Persistent anonymous ID (survives sessions)
      var anonId = localStorage.getItem('_nw_aid');
      if (!anonId) { anonId = uuid(); localStorage.setItem('_nw_aid', anonId); }

      // Session ID (resets each browser session)
      var sessionId = sessionStorage.getItem('_nw_sid');
      if (!sessionId) { sessionId = uuid(); sessionStorage.setItem('_nw_sid', sessionId); }

      // In-session event buffer (keeps last 30 events)
      var events = [];
      try { events = JSON.parse(sessionStorage.getItem('_nw_ev') || '[]'); } catch(e) {}

      function saveEvents() {
        try { sessionStorage.setItem('_nw_ev', JSON.stringify(events.slice(-30))); } catch(e) {}
      }

      function track(event, props) {
        events.push({ event: event, props: props || {}, url: window.location.href, ts: new Date().toISOString() });
        saveEvents();
      }

      // Called when user submits the contact form (anonymous → known)
      function identify(email, props) {
        fetch('/api/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            anonId: anonId,
            sessionId: sessionId,
            email: email,
            props: props || {},
            events: events,
            ctx: {
              ua: navigator.userAgent,
              lang: navigator.language,
              tz: Intl.DateTimeFormat().resolvedOptions().timeZone,
              ref: document.referrer,
              sw: screen.width,
              sh: screen.height
            },
            ts: new Date().toISOString()
          })
        }).catch(function() {});
      }

      track('page_view', { title: document.title });
      window.nwPixel = { track: track, identify: identify, anonId: anonId };
    })();
  </script>

  <!-- Plausible Custom Event Tracking -->
  <script is:inline>
    // Safe wrapper — queues events if Plausible script hasn't loaded yet (standard pattern)
    window.plausible = window.plausible || function() {
      (window.plausible.q = window.plausible.q || []).push(arguments);
    };

    (function() {
      var path = window.location.pathname;

      // 1. Service page view — fires on any /services/* page
      if (path.startsWith('/services/')) {
        var vertical = path.split('/')[2] || 'unknown';
        window.plausible('service_page_view', { props: { vertical: vertical } });
      }

      // 2. Portfolio sample view — fires on any /samples/* page
      if (path.startsWith('/samples/')) {
        var sampleName = path.split('/')[2] || 'unknown';
        window.plausible('sample_view', { props: { sample_name: sampleName } });
      }

      // 3. Blog read — fires at 60% scroll depth on /blog/* pages
      if (path.startsWith('/blog/')) {
        var blogRead = false;
        var postSlug = path.split('/')[2] || 'unknown';
        function handleBlogScroll() {
          if (blogRead) return;
          var scrolled = window.scrollY + window.innerHeight;
          var total = document.documentElement.scrollHeight;
          if (total > 0 && scrolled / total >= 0.6) {
            blogRead = true;
            window.plausible('blog_read', { props: { post_slug: postSlug } });
            window.removeEventListener('scroll', handleBlogScroll);
          }
        }
        window.addEventListener('scroll', handleBlogScroll, { passive: true });
      }

      // 4. CTA click tracking — any element with .nav-cta, .cta-btn, or data-cta attribute
      document.addEventListener('click', function(e) {
        var el = e.target && e.target.closest('[data-cta], .nav-cta, .cta-btn, .cta-primary');
        if (el) {
          var label = (el.dataset && el.dataset.cta) || el.textContent.trim().slice(0, 60);
          window.plausible('cta_click', { props: { cta_label: label, page: path } });
        }
      });
    })();
  </script>

  <!-- Scripts -->
  <script is:inline>
    // Nav scroll behavior
    const nav = document.getElementById('site-nav');
    const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 60);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Intersection Observer for scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.animate-in').forEach(el => observer.observe(el));

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"], a[href^="/#"]').forEach(a => {
      a.addEventListener('click', (e) => {
        const href = a.getAttribute('href') || '';
        const hash = href.includes('#') ? '#' + href.split('#')[1] : null;
        if (!hash) return;
        const target = document.querySelector(hash);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>
</body>
</html>
