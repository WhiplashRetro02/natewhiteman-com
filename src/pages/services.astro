</style>

<script>
  // ---- ROI Calculator (AI-003) ----
  const roiTeam    = document.getElementById('roi-team')    as HTMLInputElement | null;
  const roiHours   = document.getElementById('roi-hours')   as HTMLInputElement | null;
  const roiRate    = document.getElementById('roi-rate')    as HTMLInputElement | null;
  const roiResult  = document.getElementById('roi-result')  as HTMLElement | null;
  const roiSavings = document.getElementById('roi-savings') as HTMLElement | null;
  const roiBreak   = document.getElementById('roi-breakdown') as HTMLElement | null;
  const roiTeamD   = document.getElementById('roi-team-display')  as HTMLElement | null;
  const roiHoursD  = document.getElementById('roi-hours-display') as HTMLElement | null;
  const roiRateD   = document.getElementById('roi-rate-display')  as HTMLElement | null;

  function fmtDollars(n: number): string {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function updateROI() {
    if (!roiTeam || !roiHours || !roiRate || !roiResult || !roiSavings || !roiBreak) return;
    const team  = parseInt(roiTeam.value);
    const hours = parseInt(roiHours.value);
    const rate  = parseInt(roiRate.value);
    const annual = team * hours * rate * 52;
    const savings = annual * 0.75;
    if (roiTeamD)  roiTeamD.textContent  = String(team);
    if (roiHoursD) roiHoursD.textContent = String(hours);
    if (roiRateD)  roiRateD.textContent  = '$' + rate;
    roiResult.textContent  = fmtDollars(annual);
    roiSavings.textContent = fmtDollars(savings) + ' / yr';
    roiBreak.textContent   = `${team} ${team === 1 ? 'person' : 'people'} × ${hours} hrs/wk × $${rate}/hr × 52 weeks`;
  }

  roiTeam?.addEventListener('input', updateROI);
  roiHours?.addEventListener('input', updateROI);
  roiRate?.addEventListener('input', updateROI);
  updateROI();

  // ---- Service card accordion ----
  document.querySelectorAll<HTMLButtonElement>('.svc-header').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.svc-item') as HTMLElement;
      const detailId = btn.getAttribute('aria-controls');
      const detail = detailId ? document.getElementById(detailId) : null;
      const isOpen = item.classList.contains('open');

      // Close all others
      document.querySelectorAll('.svc-item.open').forEach((el) => {
        el.classList.remove('open');
        const otherBtn = el.querySelector<HTMLButtonElement>('.svc-header');
        const otherId = otherBtn?.getAttribute('aria-controls');
        const otherDetail = otherId ? document.getElementById(otherId) : null;
        if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
        if (otherDetail) otherDetail.hidden = true;
      });

      if (!isOpen && detail) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        detail.hidden = false;
        setTimeout(() => detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
      }
    });
  });

  // ---- Contact form ----
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const feedback = document.getElementById('form-feedback') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !feedback) return;

    const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      feedback.className = 'form-feedback error';
      feedback.textContent = 'Please fill out all fields.';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    feedback.className = 'form-feedback';
    feedback.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message }),
      });

      const data = await res.json() as { success: boolean; error?: string };

      if (data.success) {
        // Fire-and-forget identity resolution before resetting form
        if (typeof window !== 'undefined' && (window as Window & { nwPixel?: { identify: (e: string, p: object) => void } }).nwPixel) {
          (window as Window & { nwPixel: { identify: (e: string, p: object) => void } }).nwPixel.identify(email, { name, source: 'inquiry_form' });
        }
        feedback.className = 'form-feedback success';
        feedback.textContent = "Got it — I'll be in touch within a couple of business days.";
        form.reset();
      } else {
        feedback.className = 'form-feedback error';
        feedback.textContent = data.error ?? 'Something went wrong. Try emailing me directly.';
      }
    } catch {
      feedback.className = 'form-feedback error';
      feedback.textContent = 'Network error. Please try again or email me directly.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send inquiry →';
    }
  });
</script>
