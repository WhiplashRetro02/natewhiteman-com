---
import Base from '../layouts/Base.astro';
---

<Base
  title="Services — Nate Whiteman"
  description="Contract data analytics, custom dashboarding, AI enablement, and technology consulting for small and medium-sized businesses. Fixed-scope engagements under $5K."
>

  <!-- ============ PAGE HERO ============ -->
  <section class="svc-hero">
    <div class="container">
      <div class="svc-hero-inner">
        <div class="svc-eyebrow">Contract Work &amp; Consulting</div>
        <h1 class="svc-title">
          What I can<br>do for <span class="italic-accent">you</span>
        </h1>
        <p class="svc-lead">
          I work directly with small and medium-sized businesses that need serious
          data and AI capability — without the overhead of a full-time hire.
          Engagements are fixed-scope, fixed-price, and built to leave you with
          something that actually runs.
        </p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          <a href="#inquiry" class="btn btn--primary">Start a conversation &rarr;</a>
          <a href="#services" class="btn btn--ghost">See what's included &darr;</a>
        </div>
      </div>
    </div>
    <div class="svc-hero-rule" aria-hidden="true"></div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">01</span>
        <h2 class="section-heading">What I Offer</h2>
        <div class="section-rule"></div>
      </div>
      <p class="svc-intro animate-in">Click any service to see a real example engagement and pricing.</p>

      <div class="svc-list animate-in stagger-1">

        <!-- ── Dashboarding ── -->
        <div class="svc-item" data-svc="dash">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-dash">
            <div class="svc-header-left">
              <span class="svc-glyph">◈</span>
              <div>
                <div class="svc-item-tag">Most requested</div>
                <h3 class="svc-item-title">Custom Dashboarding</h3>
                <p class="svc-item-summary">Decision-ready dashboards built around the metrics your team actually acts on — connected to your real data, not template placeholders.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">from $250</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-dash" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>A 12-person regional HVAC company has revenue, job completion, and technician performance data living in three separate spreadsheets. No one can see the full picture at a glance. We build a unified operations dashboard — job pipeline, revenue by technician, customer satisfaction trend — connected directly to their existing data and refreshed automatically. Deployed, documented, and handed off with a training session.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Interactive dashboard connected to your data sources</li>
                  <li>Role-based views (owner, manager, field team)</li>
                  <li>Automated or scheduled refresh</li>
                  <li>Full documentation and 1 training session</li>
                  <li>30 days of support post-delivery</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$250 – $2,000</div>
                <div class="svc-pricing-note">Fixed scope · Fixed price · Delivered in 2–4 weeks</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

        <!-- ── Data Analytics ── -->
        <div class="svc-item" data-svc="analytics">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-analytics">
            <div class="svc-header-left">
              <span class="svc-glyph">◇</span>
              <div>
                <h3 class="svc-item-title">Contract Data Analytics</h3>
                <p class="svc-item-summary">You have data. You're not sure what it's telling you. I dig in and surface the findings that actually drive decisions.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">from $150</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-analytics" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>An e-commerce retailer notices their repeat purchase rate dropped but can't figure out why. We dig into their order history, analyze cohorts by acquisition channel, and identify that customers from one specific paid campaign have 40% lower lifetime value than all others. One clear finding — one clear action. Delivered as an interactive report your team can own.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Documented analysis with clear findings and recommendations</li>
                  <li>Executive summary written for non-technical stakeholders</li>
                  <li>Underlying analysis notebook (yours to keep and re-run)</li>
                  <li>One follow-up call to walk through findings</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$150 – $1,500</div>
                <div class="svc-pricing-note">Fixed scope · Fixed price · Delivered in 1–3 weeks</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

        <!-- ── Data Science ── -->
        <div class="svc-item" data-svc="ds">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-ds">
            <div class="svc-header-left">
              <span class="svc-glyph">△</span>
              <div>
                <h3 class="svc-item-title">Data Science</h3>
                <p class="svc-item-summary">Predictive models, forecasting, and segmentation grounded in what your business actually needs to know — explainable and practical enough to be maintained.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">from $500</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-ds" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>A property management firm wants to predict which units are likely to go vacant in the next 60 days so they can get ahead of the leasing cycle. We build a churn prediction model on their lease history, tenant behavior patterns, and maintenance records — producing a ranked watchlist that refreshes every Monday morning. Documented, deployed, and explained in plain English.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Trained model with documented methodology</li>
                  <li>Prediction pipeline connected to your data</li>
                  <li>Plain-language explanation of how it works and when to trust it</li>
                  <li>Deployment guide so your team can maintain it</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$500 – $5,000</div>
                <div class="svc-pricing-note">Fixed scope · Fixed price · Delivered in 3–6 weeks</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

        <!-- ── AI Enablement ── -->
        <div class="svc-item" data-svc="ai">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-ai">
            <div class="svc-header-left">
              <span class="svc-glyph">⬡</span>
              <div>
                <h3 class="svc-item-title">AI Enablement</h3>
                <p class="svc-item-summary">Most AI initiatives fail at the data layer. I build the foundational infrastructure that makes AI adoption real — not a demo, not a wrapper, something your team actually uses.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">from $750</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-ai" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>A 20-person law firm has 8 years of case documents sitting in Google Drive. No one can find anything quickly, and clients pay for time while staff digs through folders. We build a retrieval system that lets staff ask plain-language questions — "what's our precedent on non-compete clauses in Tennessee?" — and get back the right documents, clauses, and precedents in seconds. Deployed internally, documented, and staff-trained.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Deployed AI system connected to your existing documents or data</li>
                  <li>Internal tool your team owns — not a SaaS subscription</li>
                  <li>Admin guide for adding new documents and maintaining accuracy</li>
                  <li>Staff training session and 30-day support period</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$750 – $10,000</div>
                <div class="svc-pricing-note">Fixed scope · Fixed price · Delivered in 3–6 weeks</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

        <!-- ── Technology Consulting ── -->
        <div class="svc-item" data-svc="consulting">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-consulting">
            <div class="svc-header-left">
              <span class="svc-glyph">○</span>
              <div>
                <h3 class="svc-item-title">Technology Consulting</h3>
                <p class="svc-item-summary">Strategic and technical guidance for leaders making technology decisions — without getting sold to. Vendor evaluation, roadmaps, and honest recommendations.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">$45 / hr</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-consulting" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>A regional retailer is being pitched three different "AI analytics" platforms at $40K/year each and doesn't know how to evaluate the actual difference. We spend two weeks reviewing their data environment, auditing each vendor's real capability against their specific use case, and delivering a written recommendation memo with clear reasoning — not a scorecard, an actual decision. No commission, no referral fee.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Vendor evaluation report with documented reasoning</li>
                  <li>Architecture or tooling recommendation for your specific situation</li>
                  <li>Written decision memo your leadership team can act on</li>
                  <li>Three monthly advisory calls post-delivery</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$45 / hr</div>
                <div class="svc-pricing-note">Hourly · Flexible scope · Minimum 5 hours</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

        <!-- ── Custom CRM ── -->
        <div class="svc-item" data-svc="crm">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-crm">
            <div class="svc-header-left">
              <span class="svc-glyph">⬜</span>
              <div>
                <h3 class="svc-item-title">Custom CRM &amp; Integrations</h3>
                <p class="svc-item-summary">Off-the-shelf CRMs are built for everyone, which means they fit no one perfectly. I build lightweight, purpose-fit CRMs and wire them to the tools you already use.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">from $100</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-crm" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>A 6-person financial advisory firm is tracking client relationships across a spreadsheet, email threads, and sticky notes. Deals fall through the cracks when the team is busy. We build a simple CRM tailored to their workflow — client pipeline, follow-up reminders, and automatic sync with their email and calendar — deployed in two weeks and requiring no technical upkeep.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Custom CRM configured around your actual sales or client workflow</li>
                  <li>Integrations with your existing tools (email, calendar, Slack, etc.)</li>
                  <li>Automated follow-up triggers and pipeline stage rules</li>
                  <li>Team onboarding session and written admin guide</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$100 – $1,000</div>
                <div class="svc-pricing-note">Fixed scope · Fixed price · Delivered in 1–3 weeks</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

        <!-- ── Website Building ── -->
        <div class="svc-item" data-svc="web">
          <button class="svc-header" aria-expanded="false" aria-controls="detail-web">
            <div class="svc-header-left">
              <span class="svc-glyph">▷</span>
              <div>
                <h3 class="svc-item-title">Custom Website Building</h3>
                <p class="svc-item-summary">Fast, clean, professional websites that actually represent your business — not a template someone else's brand is already on.</p>
              </div>
            </div>
            <div class="svc-header-right">
              <span class="svc-price-preview">from $200</span>
              <span class="svc-toggle" aria-hidden="true">+</span>
            </div>
          </button>
          <div class="svc-detail" id="detail-web" hidden>
            <div class="svc-detail-inner">
              <div class="svc-example">
                <div class="svc-example-label">Example Engagement</div>
                <p>A solo contractor with 10 years of experience has no web presence beyond a Facebook page. Potential clients Google them and find nothing. We build a focused, professional site — services, credibility, and a clear way to get in touch — designed to convert visitors into inquiries. Delivered in under two weeks, hosted for near-zero cost, and built so it loads fast on any device.</p>
              </div>
              <div class="svc-deliverables-detail">
                <div class="svc-deliverables-label">What you receive</div>
                <ul>
                  <li>Fully custom website designed and built from scratch</li>
                  <li>Contact form, mobile responsiveness, and fast load times</li>
                  <li>Deployment to a hosting platform you own</li>
                  <li>Written guide for making basic content updates yourself</li>
                </ul>
              </div>
              <div class="svc-pricing">
                <div class="svc-pricing-range">$200 – $500</div>
                <div class="svc-pricing-note">Fixed scope · Fixed price · Delivered in 1–2 weeks</div>
              </div>
              <a href="#inquiry" class="btn btn--primary svc-cta">Start this project &rarr;</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ HOW I WORK ============ -->
  <section class="section" id="process">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">02</span>
        <h2 class="section-heading">How I Work</h2>
        <div class="section-rule"></div>
      </div>

      <div class="process-track animate-in stagger-1">
        <div class="process-step">
          <div class="process-step-num">01</div>
          <div class="process-step-content">
            <h4 class="process-step-title">Discovery call</h4>
            <p class="process-step-desc">
              We talk through what you're trying to solve, what data you have,
              and what success looks like. No pitch. I tell you plainly if
              I'm the right fit.
            </p>
          </div>
        </div>
        <div class="process-connector" aria-hidden="true"></div>

        <div class="process-step">
          <div class="process-step-num">02</div>
          <div class="process-step-content">
            <h4 class="process-step-title">Scoped proposal</h4>
            <p class="process-step-desc">
              I send a written proposal with a defined scope, timeline,
              deliverables, and fixed price. No hourly billing surprises.
            </p>
          </div>
        </div>
        <div class="process-connector" aria-hidden="true"></div>

        <div class="process-step">
          <div class="process-step-num">03</div>
          <div class="process-step-content">
            <h4 class="process-step-title">Execution</h4>
            <p class="process-step-desc">
              I work asynchronously with regular check-ins. You see the work
              as it progresses — not just the final output.
            </p>
          </div>
        </div>
        <div class="process-connector" aria-hidden="true"></div>

        <div class="process-step">
          <div class="process-step-num">04</div>
          <div class="process-step-content">
            <h4 class="process-step-title">Handoff</h4>
            <p class="process-step-desc">
              Documented deliverables, walkthrough sessions, and support
              during the transition period so your team can own what I built.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ INQUIRY FORM ============ -->
  <section class="section" id="inquiry">
    <div class="container container--narrow">
      <div class="section-label animate-in">
        <span class="section-num">03</span>
        <h2 class="section-heading">Get in Touch</h2>
        <div class="section-rule"></div>
      </div>

      <div class="inquiry-layout animate-in stagger-1">
        <div class="inquiry-meta">
          <p class="inquiry-intro">
            Tell me a bit about what you're working on. I read every message
            and respond within a couple of business days.
          </p>
          <div class="inquiry-notes">
            <div class="inquiry-note">
              <span class="inquiry-note-label">Typical project size</span>
              <span class="inquiry-note-val">$200 – $2,000</span>
            </div>
            <div class="inquiry-note">
              <span class="inquiry-note-label">Timeline</span>
              <span class="inquiry-note-val">1 – 6 weeks</span>
            </div>
            <div class="inquiry-note">
              <span class="inquiry-note-label">Availability</span>
              <span class="inquiry-note-val"><span class="status-dot"></span>Currently taking new clients</span>
            </div>
          </div>
        </div>

        <form class="inquiry-form" id="inquiry-form" novalidate>
          <div class="form-row">
            <div class="form-field">
              <label class="form-label" for="name">Name</label>
              <input
                class="form-input"
                type="text"
                id="name"
                name="name"
                placeholder="Your name"
                autocomplete="name"
                required
              />
            </div>
            <div class="form-field">
              <label class="form-label" for="email">Email</label>
              <input
                class="form-input"
                type="email"
                id="email"
                name="email"
                placeholder="you@company.com"
                autocomplete="email"
                required
              />
            </div>
          </div>

          <div class="form-field">
            <label class="form-label" for="message">What are you working on?</label>
            <textarea
              class="form-input form-textarea"
              id="message"
              name="message"
              placeholder="Describe the problem or project — the messier the better. I can help you shape it."
              rows="6"
              required
            ></textarea>
          </div>

          <div class="form-actions">
            <button class="btn btn--primary" type="submit" id="submit-btn">
              Send inquiry &rarr;
            </button>
            <span class="form-privacy">No spam. No mailing lists. Just a real reply.</span>
          </div>

          <div class="form-feedback" id="form-feedback" aria-live="polite"></div>
        </form>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ---- HERO ---- */
  .svc-hero {
    padding: calc(var(--space-4xl) + 60px) 0 var(--space-3xl);
    position: relative;
  }

  .svc-hero-inner {
    max-width: 720px;
  }

  .svc-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-muted);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .svc-eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .svc-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 7vw, 84px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -3px;
    margin-bottom: var(--space-xl);
  }

  .svc-lead {
    font-size: 17px;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 580px;
    margin-bottom: var(--space-xl);
  }

  .svc-hero-rule {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-default) 30%, var(--border-default) 70%, transparent);
  }

  /* ---- SERVICES LIST ---- */
  .svc-intro {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--text-tertiary);
    margin-bottom: var(--space-xl);
  }

  .svc-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border-subtle);
    border: 1px solid var(--border-default);
  }

  .svc-item {
    background: var(--bg-primary);
  }

  .svc-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    text-align: left;
    transition: background var(--duration-base);
  }

  .svc-header:hover {
    background: var(--bg-elevated);
  }

  .svc-item.open .svc-header {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-default);
  }

  .svc-header-left {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    flex: 1;
  }

  .svc-glyph {
    font-size: 28px;
    opacity: 0.4;
    flex-shrink: 0;
    margin-top: 4px;
    transition: opacity var(--duration-base);
    line-height: 1;
  }

  .svc-item.open .svc-glyph,
  .svc-header:hover .svc-glyph {
    opacity: 0.8;
  }

  .svc-item-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--border-accent);
    padding: 2px 8px;
    display: inline-block;
    margin-bottom: 6px;
  }

  .svc-item-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-bottom: 6px;
    transition: color var(--duration-fast);
  }

  .svc-header:hover .svc-item-title,
  .svc-item.open .svc-item-title {
    color: var(--accent);
  }

  .svc-item-summary {
    font-size: 13px;
    color: var(--text-tertiary);
    line-height: 1.65;
    max-width: 600px;
  }

  .svc-header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  .svc-price-preview {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .svc-toggle {
    width: 28px;
    height: 28px;
    border: 1px solid var(--border-default);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--text-tertiary);
    transition: all var(--duration-base);
    flex-shrink: 0;
    line-height: 1;
  }

  .svc-item.open .svc-toggle {
    content: '×';
    border-color: var(--accent-muted);
    color: var(--accent);
    transform: rotate(45deg);
  }

  /* ---- EXPANDED DETAIL ---- */
  .svc-detail {
    overflow: hidden;
  }

  .svc-detail[hidden] {
    display: none;
  }

  .svc-detail-inner {
    padding: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
    background: var(--bg-elevated);
  }

  .svc-example {
    grid-column: 1 / -1;
  }

  .svc-example-label,
  .svc-deliverables-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent-muted);
    margin-bottom: var(--space-md);
  }

  .svc-example p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.75;
    border-left: 2px solid var(--border-accent);
    padding-left: var(--space-lg);
  }

  .svc-deliverables-detail ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .svc-deliverables-detail li {
    font-size: 13px;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .svc-deliverables-detail li::before {
    content: '→';
    color: var(--accent-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .svc-pricing {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-lg);
    border: 1px solid var(--border-accent);
    background: var(--accent-glow);
    align-self: start;
  }

  .svc-pricing-range {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--text-primary);
  }

  .svc-pricing-note {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--accent-muted);
  }

  .svc-cta {
    align-self: end;
  }

  /* ---- PROCESS ---- */
  .process-track {
    display: flex;
    align-items: flex-start;
    gap: 0;
    position: relative;
  }

  .process-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    position: relative;
    transition: background var(--duration-base);
    min-height: 200px;
  }

  .process-step:hover {
    background: var(--bg-surface);
  }

  .process-connector {
    width: 1px;
    flex-shrink: 0;
  }

  .process-step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--accent-muted);
  }

  .process-step-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.2px;
    color: var(--text-primary);
  }

  .process-step-desc {
    font-size: 13px;
    color: var(--text-tertiary);
    line-height: 1.7;
  }

  /* ---- INQUIRY FORM ---- */
  .inquiry-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-3xl);
    align-items: flex-start;
  }

  .inquiry-intro {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: var(--space-xl);
  }

  .inquiry-notes {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .inquiry-note {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
  }

  .inquiry-note-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .inquiry-note-val {
    font-size: 14px;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--node-green);
    animation: pulse 2s ease-in-out infinite;
  }

  /* Form */
  .inquiry-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .form-input {
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    padding: 14px 16px;
    outline: none;
    width: 100%;
    transition: border-color var(--duration-fast);
    -webkit-appearance: none;
    border-radius: 0;
  }

  .form-input::placeholder {
    color: var(--text-ghost);
  }

  .form-input:focus {
    border-color: var(--accent-muted);
    background: var(--bg-surface);
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.65;
  }

  .form-actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .form-privacy {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-ghost);
    letter-spacing: 0.5px;
  }

  .form-feedback {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.5px;
    min-height: 20px;
  }

  .form-feedback.success { color: var(--node-green); }
  .form-feedback.error   { color: var(--node-red); }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 768px) {
    .svc-detail-inner { grid-template-columns: 1fr; }
    .svc-pricing { align-self: auto; }
    .svc-cta { align-self: auto; }
    .process-track { flex-direction: column; }
    .inquiry-layout { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ---- Service card accordion ----
  document.querySelectorAll<HTMLButtonElement>('.svc-header').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.svc-item') as HTMLElement;
      const detailId = btn.getAttribute('aria-controls');
      const detail = detailId ? document.getElementById(detailId) : null;
      const isOpen = item.classList.contains('open');

      // Close all others
      document.querySelectorAll('.svc-item.open').forEach((el) => {
        el.classList.remove('open');
        const otherBtn = el.querySelector<HTMLButtonElement>('.svc-header');
        const otherId = otherBtn?.getAttribute('aria-controls');
        const otherDetail = otherId ? document.getElementById(otherId) : null;
        if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
        if (otherDetail) otherDetail.hidden = true;
      });

      if (!isOpen && detail) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        detail.hidden = false;
        setTimeout(() => detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
      }
    });
  });

  // ---- Contact form ----
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const feedback = document.getElementById('form-feedback') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !feedback) return;

    const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      feedback.className = 'form-feedback error';
      feedback.textContent = 'Please fill out all fields.';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    feedback.className = 'form-feedback';
    feedback.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message }),
      });

      const data = await res.json() as { success: boolean; error?: string };

      if (data.success) {
        feedback.className = 'form-feedback success';
        feedback.textContent = "Got it — I'll be in touch within a couple of business days.";
        form.reset();
      } else {
        feedback.className = 'form-feedback error';
        feedback.textContent = data.error ?? 'Something went wrong. Try emailing me directly.';
      }
    } catch {
      feedback.className = 'form-feedback error';
      feedback.textContent = 'Network error. Please try again or email me directly.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send inquiry →';
    }
  });
</script>
