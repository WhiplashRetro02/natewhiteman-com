---
import Base from '../layouts/Base.astro';
---

<Base
  title="Knoxville Small Business Data & CRM Services | Nate Whiteman"
  description="Custom CRMs, dashboards, and automation for Knoxville SMBs. Fixed price, fast delivery, $49/mo to maintain. Built by a local data consultant."
>

  <!-- ============ HERO ============ -->
  <section class="kx-hero">
    <div class="kx-hero-bg" aria-hidden="true">
      <svg class="kx-tn-shape" viewBox="0 0 500 130" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20,45 L60,35 L120,30 L180,28 L220,32 L260,28 L320,30 L380,35 L430,40 L460,55 L450,75 L420,85 L380,88 L320,85 L260,80 L220,82 L180,80 L120,85 L60,88 L20,80 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <text x="240" y="62" text-anchor="middle" font-family="monospace" font-size="9" fill="currentColor" letter-spacing="4">TENNESSEE</text>
        <circle cx="295" cy="57" r="3" fill="currentColor"/>
        <text x="295" y="48" text-anchor="middle" font-family="monospace" font-size="7" fill="currentColor" letter-spacing="1">KNOXVILLE</text>
      </svg>
    </div>
    <div class="container">
      <div class="kx-hero-inner">
        <div class="kx-eyebrow">Knoxville &middot; Knox County &middot; East Tennessee</div>
        <h1 class="kx-title">
          Your Knoxville Business<br>
          Deserves Better Than<br>
          <span class="italic-accent">Spreadsheets</span>
        </h1>
        <p class="kx-lead">
          I build custom CRMs, dashboards, and automation tools for local businesses —
          fixed price, fast delivery, and a flat monthly fee to keep everything running.
        </p>
        <p class="kx-sub">Based in Knoxville. Built for businesses between $500K–$10M. No bloated agency overhead.</p>
        <div class="kx-hero-ctas">
          <a href="https://calendly.com/new102302/30min" target="_blank" rel="noopener" class="btn btn--primary">Book a Free 20-Minute Call &rarr;</a>
          <a href="#packages" class="btn btn--ghost">See what's included &darr;</a>
        </div>
      </div>
    </div>
    <div class="kx-hero-rule" aria-hidden="true"></div>
  </section>

  <!-- ============ TRUST BAR ============ -->
  <div class="kx-trust-bar" aria-label="Credibility signals">
    <div class="container">
      <div class="kx-trust-signals">
        <span class="kx-trust-item">Fixed-Price Engagements</span>
        <span class="kx-trust-sep" aria-hidden="true">&middot;</span>
        <span class="kx-trust-item">Knoxville-Based</span>
        <span class="kx-trust-sep" aria-hidden="true">&middot;</span>
        <span class="kx-trust-item">Delivered in Days, Not Months</span>
        <span class="kx-trust-sep" aria-hidden="true">&middot;</span>
        <span class="kx-trust-item">You Own Everything Built</span>
      </div>
    </div>
  </div>

  <!-- ============ PROBLEM ============ -->
  <section class="section kx-problem" id="problem">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">01</span>
        <h2 class="section-heading">The Real Cost of Doing It Manually</h2>
        <div class="section-rule"></div>
      </div>

      <div class="kx-problem-body animate-in stagger-1">
        <p class="kx-problem-headline">
          Most Knoxville businesses are running on systems built for a business half their size.
        </p>
        <div class="kx-problem-copy">
          <p>You started with a spreadsheet. Then another one. Then someone made a Google Drive folder. Now you have three sources of truth and none of them agree.</p>
          <p>It's not a data problem. It's a systems problem — and it's costing you more than you think.</p>
        </div>
      </div>

      <div class="kx-stats animate-in stagger-2">
        <div class="kx-stat">
          <div class="kx-stat-icon" aria-hidden="true">⏱</div>
          <div class="kx-stat-val">6–10 hours/week</div>
          <div class="kx-stat-lbl">Lost to manual reporting and data hunting</div>
        </div>
        <div class="kx-stat">
          <div class="kx-stat-icon" aria-hidden="true">💸</div>
          <div class="kx-stat-val">$40K–$80K/year</div>
          <div class="kx-stat-lbl">The real cost of 2–3 people doing manual work</div>
        </div>
        <div class="kx-stat">
          <div class="kx-stat-icon" aria-hidden="true">📉</div>
          <div class="kx-stat-val">Decisions delayed</div>
          <div class="kx-stat-lbl">Because the numbers aren't ready when you need them</div>
        </div>
      </div>

      <div class="kx-problem-footer animate-in stagger-3">
        <p class="kx-problem-transition">
          This is fixable. And it doesn't require a six-figure software contract or an in-house data team.
        </p>
        <p class="kx-problem-roi-link">
          &rarr; <em>Curious what that's actually worth to your business?
          <a href="/services#roi">Use the ROI calculator on my services page.</a></em>
        </p>
      </div>
    </div>
  </section>

  <!-- ============ PACKAGES ============ -->
  <section class="section kx-packages-section" id="packages">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">02</span>
        <h2 class="section-heading">What I Offer Knoxville Businesses</h2>
        <div class="section-rule"></div>
      </div>

      <p class="kx-packages-intro animate-in">
        Two options depending on where you are and where you want to go. Both are fixed-price. Both leave you with something you own.
      </p>

      <div class="kx-packages animate-in stagger-1">

        <!-- Starter -->
        <div class="kx-package">
          <div class="kx-package-badge">Most Popular &middot; Best for Getting Started</div>
          <div class="kx-package-name">The Knoxville Starter</div>
          <p class="kx-package-tagline">Get your business organized and running on real systems in under a week.</p>
          <ul class="kx-package-features">
            <li>Custom CRM built around your actual sales or client workflow <em>(not a template you have to force-fit)</em></li>
            <li>Basic operations or pipeline dashboard — one clean view of what matters</li>
            <li>Connected to your existing tools: email, calendar, spreadsheets, or forms</li>
            <li>Automated follow-up triggers so nothing falls through the cracks</li>
            <li>1 onboarding session + written admin guide</li>
            <li>30 days of support after delivery</li>
          </ul>
          <div class="kx-package-pricing">
            <div class="kx-price-setup">
              <span class="kx-price-amt">$297</span>
              <span class="kx-price-note">— one time</span>
            </div>
            <div class="kx-price-monthly">
              <span class="kx-price-amt">$49<span class="kx-price-period">/month</span></span>
              <span class="kx-price-note">maintenance, updates, and support</span>
            </div>
            <div class="kx-price-cancel">Cancel anytime. No contracts.</div>
          </div>
          <div class="kx-package-timeline">3–5 business days after kickoff call</div>
          <a href="#inquiry" class="btn btn--primary">Start the Starter Pack &rarr;</a>
          <p class="kx-package-reassure">
            Not sure if this fits?
            <a href="https://calendly.com/new102302/30min" target="_blank" rel="noopener">Book a free 20-minute call</a>
            and I'll tell you plainly.
          </p>
        </div>

        <!-- Pro -->
        <div class="kx-package kx-package--pro">
          <div class="kx-package-badge kx-package-badge--pro">For Businesses Ready to Scale &middot; Most Comprehensive</div>
          <div class="kx-package-name">The Knoxville Pro Build</div>
          <p class="kx-package-tagline">A full data and operations infrastructure — custom-built for how your business actually runs.</p>
          <ul class="kx-package-features">
            <li>Everything in the Starter Pack, plus:</li>
            <li>Multi-view dashboard system <em>(owner view, manager view, team view)</em></li>
            <li>Predictive or trend analysis layer — forecasting, patterns, leading indicators</li>
            <li>AI-assisted document or operations tool <em>(e.g., quote generator, report automation, internal search)</em></li>
            <li>Full ETL pipeline — data flows automatically, no manual exports</li>
            <li>2 onboarding sessions + full technical documentation</li>
            <li>Priority support — 60-day post-delivery coverage</li>
            <li>Quarterly check-in call included in monthly fee</li>
          </ul>
          <div class="kx-package-pricing">
            <div class="kx-price-setup">
              <span class="kx-price-amt">$1,200</span>
              <span class="kx-price-note">— one time</span>
            </div>
            <div class="kx-price-monthly">
              <span class="kx-price-amt">$149<span class="kx-price-period">/month</span></span>
              <span class="kx-price-note">full managed support + quarterly strategy call</span>
            </div>
            <div class="kx-price-cancel">Cancel anytime. No contracts.</div>
          </div>
          <div class="kx-package-timeline">2–4 weeks depending on scope</div>
          <a href="#inquiry" class="btn btn--primary">Start the Pro Build &rarr;</a>
          <p class="kx-package-reassure">
            Not sure which fits?
            <a href="/services#how-i-work">See how I work &rarr;</a>
            or just <a href="#inquiry">send me a message.</a>
          </p>
        </div>

      </div>

      <!-- Comparison table -->
      <div class="kx-comparison animate-in stagger-2">
        <div class="kx-comparison-label">Package Comparison</div>
        <div class="kx-table-wrap">
          <table class="kx-table" aria-label="Feature comparison between Knoxville Starter and Knoxville Pro Build">
            <thead>
              <tr>
                <th class="kx-th-feature" scope="col"></th>
                <th class="kx-th" scope="col">Starter<br><span class="kx-th-price">$297 + $49/mo</span></th>
                <th class="kx-th kx-th--pro" scope="col">Pro Build<br><span class="kx-th-price">$1,200 + $149/mo</span></th>
              </tr>
            </thead>
            <tbody>
              {[
                ["Custom CRM",               "✓",      "✓"],
                ["Operations Dashboard",     "Basic",  "Multi-view"],
                ["Tool Integrations",        "✓",      "✓"],
                ["Automated Workflows",      "✓",      "✓"],
                ["Predictive / Trend Layer", "—",      "✓"],
                ["AI-Assisted Tool",         "—",      "✓"],
                ["Automated Data Pipeline",  "—",      "✓"],
                ["Onboarding Sessions",      "1",      "2"],
                ["Documentation",           "✓",      "Full Technical"],
                ["Post-Delivery Support",   "30 days", "60 days"],
                ["Quarterly Strategy Call", "—",      "✓"],
                ["Delivery Time",           "3–5 days","2–4 weeks"],
              ].map(([feature, starter, pro]) => (
                <tr>
                  <td class="kx-td-feature" scope="row">{feature}</td>
                  <td class="kx-td">{starter}</td>
                  <td class="kx-td kx-td--pro">{pro}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="section kx-process-section" id="how-it-works">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">03</span>
        <h2 class="section-heading">Simple. Fast. No Surprises.</h2>
        <div class="section-rule"></div>
      </div>

      <div class="kx-steps animate-in stagger-1">
        <div class="kx-step">
          <div class="kx-step-num">01</div>
          <div class="kx-step-content">
            <div class="kx-step-title">Discovery Call <span class="kx-step-sub">Free &middot; 20 min</span></div>
            <p class="kx-step-body">We talk through what you're dealing with, what tools you're using, and what success looks like. I'll tell you plainly which package fits — or if neither does.</p>
          </div>
        </div>
        <div class="kx-step">
          <div class="kx-step-num">02</div>
          <div class="kx-step-content">
            <div class="kx-step-title">Scoped Proposal</div>
            <p class="kx-step-body">I send a written proposal with a defined scope, exact price, timeline, and deliverables. No hourly billing. No change orders.</p>
          </div>
        </div>
        <div class="kx-step">
          <div class="kx-step-num">03</div>
          <div class="kx-step-content">
            <div class="kx-step-title">Build</div>
            <p class="kx-step-body">I work fast. Most Starter builds are done in under a week. You see progress as it happens — not just at the end.</p>
          </div>
        </div>
        <div class="kx-step">
          <div class="kx-step-num">04</div>
          <div class="kx-step-content">
            <div class="kx-step-title">Handoff + Ongoing</div>
            <p class="kx-step-body">Documented delivery, walkthrough session, and then I'm in your corner monthly. Updates, questions, and improvements — covered.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WORK SAMPLES ============ -->
  <section class="section kx-samples-section" id="samples">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">04</span>
        <h2 class="section-heading">Not Mockups. Real Deliverables.</h2>
        <div class="section-rule"></div>
      </div>

      <p class="kx-samples-intro animate-in">Every example below was built the same way yours would be — scoped, priced, delivered, and documented.</p>

      <div class="kx-sample-cards animate-in stagger-1">
        <div class="kx-sample-card">
          <div class="kx-sample-label">Dashboard</div>
          <div class="kx-sample-title">Operations View — Property Management</div>
          <p class="kx-sample-desc">Lease pipeline, vacancy risk, and revenue by unit — one screen, refreshed automatically.</p>
          <a href="/samples/property-dashboard" target="_blank" rel="noopener" class="kx-sample-link">View sample &rarr;</a>
        </div>
        <div class="kx-sample-card">
          <div class="kx-sample-label">CRM</div>
          <div class="kx-sample-title">Client Pipeline — Financial Services</div>
          <p class="kx-sample-desc">6-person firm replaced sticky notes and email threads with a purpose-fit CRM wired to their calendar.</p>
          <a href="/samples/crm-dashboard" target="_blank" rel="noopener" class="kx-sample-link">View sample &rarr;</a>
        </div>
        <div class="kx-sample-card">
          <div class="kx-sample-label">Vendor Evaluation</div>
          <div class="kx-sample-title">Analytics Platform Decision — Regional Retail</div>
          <p class="kx-sample-desc">Written recommendation memo comparing three $40K/year platforms against actual business needs.</p>
          <a href="/samples/vendor-evaluation" target="_blank" rel="noopener" class="kx-sample-link">View sample &rarr;</a>
        </div>
      </div>

      <p class="kx-samples-hook animate-in">
        Want to see what this looks like for your industry specifically?
        <a href="#inquiry">Send me a message.</a>
      </p>
    </div>
  </section>

  <!-- ============ WHO THIS IS FOR ============ -->
  <section class="section kx-fit-section" id="fit">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">05</span>
        <h2 class="section-heading">Built for Knoxville businesses growing faster than their systems.</h2>
        <div class="section-rule"></div>
      </div>

      <div class="kx-fit-grid animate-in stagger-1">
        <div class="kx-fit-col kx-fit-col--yes">
          <div class="kx-fit-col-label">&#10003; Good fit</div>
          <ul class="kx-fit-list">
            <li>You run a business in Knoxville or Knox County with 2–30 employees</li>
            <li>Your reporting still lives in spreadsheets or someone's inbox</li>
            <li>You're using tools like QuickBooks, HubSpot, Salesforce, or Shopify but not getting real insight from them</li>
            <li>You want something custom you own — not another $400/month SaaS subscription</li>
            <li>You've been burned by a vendor who overpromised and delivered a template</li>
          </ul>
        </div>
        <div class="kx-fit-col kx-fit-col--no">
          <div class="kx-fit-col-label">&#10007; Probably not a fit</div>
          <ul class="kx-fit-list">
            <li>You need someone to maintain your work indefinitely with zero documentation handoff</li>
            <li>Your budget is under $297</li>
            <li>You want AI buzzwords without a real business problem to solve</li>
            <li>You already have an in-house data team</li>
          </ul>
        </div>
      </div>

      <p class="kx-fit-closing animate-in">
        If you're not sure which column you're in —
        <a href="#inquiry">send me a message.</a> I'll tell you honestly.
      </p>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="section kx-faq-section" id="faq">
    <div class="container container--narrow">
      <div class="section-label animate-in">
        <span class="section-num">06</span>
        <h2 class="section-heading">Common Questions</h2>
        <div class="section-rule"></div>
      </div>

      <div class="kx-faq animate-in stagger-1">

        <details class="kx-faq-item">
          <summary class="kx-faq-q">What if I'm not technical at all?</summary>
          <div class="kx-faq-a">That's exactly who this is built for. I document everything in plain English and run a walkthrough session before I hand anything off. You don't need to understand how it works — you just need to be able to use it.</div>
        </details>

        <details class="kx-faq-item">
          <summary class="kx-faq-q">What does the monthly fee actually cover?</summary>
          <div class="kx-faq-a">Updates when something changes in your business (new pipeline stage, new team member, new data source), bug fixes if anything breaks, and a direct line to me if you have questions. It's not a retainer for new work — it's maintenance so what I built keeps running.</div>
        </details>

        <details class="kx-faq-item">
          <summary class="kx-faq-q">Do I need any specific software?</summary>
          <div class="kx-faq-a">Usually not. I work with whatever you're already using — Google Workspace, Microsoft 365, QuickBooks, most CRMs, Shopify, and others. I'll tell you in the discovery call if there's anything you'd need to add.</div>
        </details>

        <details class="kx-faq-item">
          <summary class="kx-faq-q">What if I want to cancel the monthly fee?</summary>
          <div class="kx-faq-a">No contracts. Cancel anytime. Everything I built stays with you — it's yours. It just won't have active support or updates.</div>
        </details>

        <details class="kx-faq-item">
          <summary class="kx-faq-q">Can I start with the Starter and upgrade to Pro later?</summary>
          <div class="kx-faq-a">Yes. The Starter is built with that in mind. Upgrading means extending what's already there — not starting over.</div>
        </details>

        <details class="kx-faq-item">
          <summary class="kx-faq-q">Are you actually local to Knoxville?</summary>
          <div class="kx-faq-a">Yes. Based in Knoxville. Most work is done remotely but I'm happy to meet in person if that's useful.</div>
        </details>

      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA + FORM ============ -->
  <section class="kx-cta-section" id="inquiry">
    <div class="container container--narrow">
      <div class="kx-cta-header">
        <div class="kx-cta-eyebrow">Let's Talk</div>
        <h2 class="kx-cta-title">Ready to stop running your business on spreadsheets?</h2>
        <p class="kx-cta-sub">Book a free 20-minute call. No pitch — just an honest conversation about whether this makes sense for you.</p>
        <a href="https://calendly.com/new102302/30min" target="_blank" rel="noopener" class="btn btn--primary kx-calendly-btn">Book a Free Call &rarr;</a>
        <p class="kx-cta-or">Or send a message below &darr;</p>
      </div>

      <form class="kx-form" id="kx-inquiry-form" novalidate>
        <div class="kx-form-row kx-form-row--2">
          <div class="kx-field">
            <label for="kx-name">Name <span class="kx-required" aria-hidden="true">*</span></label>
            <input type="text" id="kx-name" name="name" required autocomplete="name" />
          </div>
          <div class="kx-field">
            <label for="kx-business">Business name <span class="kx-required" aria-hidden="true">*</span></label>
            <input type="text" id="kx-business" name="business" required autocomplete="organization" />
          </div>
        </div>
        <div class="kx-form-row kx-form-row--2">
          <div class="kx-field">
            <label for="kx-email">Email <span class="kx-required" aria-hidden="true">*</span></label>
            <input type="email" id="kx-email" name="email" required autocomplete="email" />
          </div>
          <div class="kx-field">
            <label for="kx-phone">Phone <span class="kx-optional">(optional)</span></label>
            <input type="tel" id="kx-phone" name="phone" autocomplete="tel" />
          </div>
        </div>
        <div class="kx-field">
          <label for="kx-package">What package are you interested in?</label>
          <select id="kx-package" name="package">
            <option value="Not sure yet">Not sure yet</option>
            <option value="Knoxville Starter ($297 + $49/mo)">Knoxville Starter — $297 + $49/mo</option>
            <option value="Knoxville Pro Build ($1,200 + $149/mo)">Knoxville Pro Build — $1,200 + $149/mo</option>
          </select>
        </div>
        <div class="kx-field">
          <label for="kx-message">What are you working on? <span class="kx-required" aria-hidden="true">*</span></label>
          <textarea id="kx-message" name="message" rows="4" required placeholder="Tell me about your business and the problem you're trying to solve."></textarea>
        </div>

        <button type="submit" class="btn btn--primary kx-submit-btn">Send it &rarr;</button>

        <div class="kx-form-status kx-form-status--success" id="kx-success" hidden aria-live="polite">
          Message sent. I'll get back to you within one business day.
        </div>
        <div class="kx-form-status kx-form-status--error" id="kx-error" hidden aria-live="polite">
          Something went wrong — please email <a href="mailto:nate@natewhiteman.com">nate@natewhiteman.com</a> directly.
        </div>
      </form>

      <p class="kx-form-note">No spam. No mailing lists. I read every message and respond within one business day.</p>
    </div>
  </section>

  <!-- ============ PAGE FOOTER ============ -->
  <div class="kx-page-footer">
    <div class="container">
      <div class="kx-page-footer-links">
        <a href="/">&larr; Back to natewhiteman.com</a>
        <span aria-hidden="true">|</span>
        <a href="/services">See all services &rarr;</a>
        <span aria-hidden="true">|</span>
        <a href="/samples/property-dashboard">View work samples &rarr;</a>
      </div>
    </div>
  </div>

</Base>

<script>
  const form = document.getElementById('kx-inquiry-form') as HTMLFormElement | null;
  const successEl = document.getElementById('kx-success') as HTMLElement | null;
  const errorEl = document.getElementById('kx-error') as HTMLElement | null;
  const submitBtn = form?.querySelector('.kx-submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
    const business = (form.elements.namedItem('business') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const phone = (form.elements.namedItem('phone') as HTMLInputElement).value.trim();
    const packageInterest = (form.elements.namedItem('package') as HTMLSelectElement).value;
    const messageText = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    if (!name || !business || !email || !messageText) return;

    const fullMessage = [
      `Business: ${business}`,
      phone ? `Phone: ${phone}` : null,
      `Package Interest: ${packageInterest}`,
      '',
      messageText,
    ].filter(Boolean).join('\n');

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
    }

    // Identify in pixel if available
    const pixel = (window as unknown as Record<string, unknown>).nwPixel as
      { identify: (email: string, props: Record<string, string>) => void } | undefined;
    pixel?.identify(email, { name, source: 'knoxville-landing' });

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message: fullMessage }),
      });

      if (res.ok) {
        form.reset();
        if (successEl) successEl.hidden = false;
        if (errorEl) errorEl.hidden = true;
      } else {
        throw new Error('Request failed');
      }
    } catch {
      if (errorEl) errorEl.hidden = false;
      if (successEl) successEl.hidden = true;
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send it →';
      }
    }
  });
</script>

