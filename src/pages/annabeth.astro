---
import Base from '../layouts/Base.astro';
---

<Base
  title="Annabeth — AI-Powered Investigation Platform | Nate Whiteman"
  description="Annabeth is a proprietary AI-powered intelligence platform for private investigators and red teams. Agentic workflows, automated reconnaissance, and legally defensible evidence management."
>

  <style>
    /* --- ANNABETH PAGE STYLES --- */
    .an-hero {
      min-height: 90vh;
      display: flex;
      align-items: center;
      padding: var(--space-4xl) 0 var(--space-3xl);
      position: relative;
      overflow: hidden;
    }

    .an-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        radial-gradient(ellipse at 70% 20%, rgba(94, 141, 186, 0.06) 0%, transparent 60%),
        radial-gradient(ellipse at 30% 80%, rgba(138, 109, 186, 0.04) 0%, transparent 50%);
      pointer-events: none;
    }

    .an-hero-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
      align-items: center;
    }

    .an-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--node-blue);
      margin-bottom: var(--space-lg);
      padding: 6px 14px;
      border: 1px solid rgba(94, 141, 186, 0.2);
      background: rgba(94, 141, 186, 0.05);
      width: fit-content;
    }

    .an-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--node-blue);
      animation: pulse 2s ease-in-out infinite;
    }

    .an-title {
      font-family: var(--font-display);
      font-size: clamp(56px, 7vw, 96px);
      font-weight: 800;
      letter-spacing: -3px;
      line-height: 0.9;
      margin-bottom: var(--space-md);
    }

    .an-title .subtitle {
      display: block;
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 0.35em;
      letter-spacing: 0;
      color: var(--text-secondary);
      margin-top: 8px;
    }

    .an-tagline {
      font-family: var(--font-mono);
      font-size: 13px;
      letter-spacing: 1px;
      color: var(--node-blue);
      margin-bottom: var(--space-lg);
    }

    .an-desc {
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.8;
      max-width: 500px;
      margin-bottom: var(--space-xl);
    }

    .an-ctas {
      display: flex;
      gap: var(--space-md);
    }

    .btn--blue {
      background: var(--node-blue);
      color: var(--bg-void);
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 16px 32px;
      border: none;
      cursor: pointer;
      transition: all var(--duration-base) var(--ease-out);
      text-decoration: none;
      display: inline-block;
    }

    .btn--blue:hover {
      background: var(--text-primary);
      transform: translateY(-1px);
    }

    /* --- CONSOLE MOCKUP --- */
    .console-mock {
      background: var(--bg-elevated);
      border: 1px solid var(--border-default);
      overflow: hidden;
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1.7;
      max-height: 520px;
    }

    .console-chrome {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: rgba(255,255,255,0.02);
      border-bottom: 1px solid var(--border-subtle);
    }

    .console-chrome .dot { width: 8px; height: 8px; border-radius: 50%; }
    .console-chrome .dot.r { background: #e05252; }
    .console-chrome .dot.y { background: #e0c452; }
    .console-chrome .dot.g { background: #52e07a; }
    .console-chrome .tab-bar {
      margin-left: 12px;
      display: flex;
      gap: 2px;
    }
    .console-chrome .tab {
      padding: 4px 12px;
      font-size: 9px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--text-ghost);
      border: 1px solid transparent;
    }
    .console-chrome .tab.active {
      color: var(--node-blue);
      border-color: var(--border-default);
      background: var(--bg-surface);
    }

    .console-body {
      padding: 16px;
      overflow-y: auto;
      max-height: 440px;
    }

    .console-line {
      margin-bottom: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .c-time { color: var(--text-ghost); }
    .c-tool { color: var(--node-purple); }
    .c-type { color: var(--text-tertiary); }
    .c-val  { color: var(--text-secondary); }
    .c-sev-crit { color: #e05252; font-weight: 500; }
    .c-sev-high { color: #e0a052; }
    .c-sev-conf { color: var(--node-green); }
    .c-prompt { color: var(--node-blue); }
    .c-ai { color: var(--accent); }

    .console-divider {
      border: none;
      border-top: 1px solid var(--border-subtle);
      margin: 12px 0;
    }

    /* --- STATS BAR --- */
    .an-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--border-subtle);
      border: 1px solid var(--border-default);
      margin: var(--space-3xl) 0;
    }

    .an-stat {
      background: var(--bg-primary);
      padding: var(--space-xl) var(--space-lg);
      text-align: center;
    }

    .an-stat-num {
      font-family: var(--font-display);
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -1px;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .an-stat-num .unit {
      font-size: 16px;
      color: var(--text-tertiary);
      font-weight: 400;
    }

    .an-stat-label {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }

    /* --- CAPABILITIES --- */
    .cap-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    .cap-card {
      background: var(--bg-elevated);
      border: 1px solid var(--border-default);
      padding: var(--space-xl);
      transition: all var(--duration-base);
      position: relative;
      overflow: hidden;
    }

    .cap-card:hover {
      border-color: var(--border-strong);
      background: var(--bg-surface);
    }

    .cap-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--duration-slow) var(--ease-out);
    }

    .cap-card:hover::before { transform: scaleX(1); }
    .cap-card:nth-child(1)::before { background: var(--node-blue); }
    .cap-card:nth-child(2)::before { background: var(--node-green); }
    .cap-card:nth-child(3)::before { background: var(--node-purple); }
    .cap-card:nth-child(4)::before { background: var(--accent); }
    .cap-card:nth-child(5)::before { background: var(--node-red); }
    .cap-card:nth-child(6)::before { background: var(--node-blue); }

    .cap-icon {
      font-size: 24px;
      margin-bottom: var(--space-md);
      opacity: 0.6;
    }

    .cap-name {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 600;
      margin-bottom: var(--space-sm);
    }

    .cap-desc {
      font-size: 13px;
      color: var(--text-tertiary);
      line-height: 1.7;
    }

    /* --- HOW IT WORKS --- */
    .how-track {
      display: flex;
      align-items: stretch;
      gap: 0;
    }

    .how-step {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
      padding: var(--space-xl) var(--space-lg);
      background: var(--bg-elevated);
      border: 1px solid var(--border-default);
      position: relative;
      transition: background var(--duration-base);
    }

    .how-step:not(:last-child) {
      border-right: none;
    }

    .how-step:hover {
      background: var(--bg-surface);
    }

    .how-step::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--node-blue);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--duration-slow) var(--ease-out);
    }

    .how-step:hover::before {
      transform: scaleX(1);
    }

    .how-step-num {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 2px;
      color: var(--accent-muted);
    }

    .how-step-title {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .how-step-desc {
      font-size: 13px;
      color: var(--text-tertiary);
      line-height: 1.7;
    }

    /* --- PERSONA SECTION --- */
    .persona-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border-subtle);
      border: 1px solid var(--border-default);
    }

    .persona-cell {
      background: var(--bg-primary);
      padding: var(--space-xl);
    }

    .persona-indicator {
      font-family: var(--font-mono);
      font-size: 11px;
      margin-bottom: var(--space-md);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .persona-indicator .dot {
      width: 8px; height: 8px; border-radius: 50%;
    }

    .persona-indicator .dot.blue { background: var(--node-blue); }
    .persona-indicator .dot.red { background: var(--node-red); }
    .persona-indicator .dot.gold { background: var(--accent); }

    .persona-name {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      margin-bottom: var(--space-sm);
    }

    .persona-desc {
      font-size: 13px;
      color: var(--text-tertiary);
      line-height: 1.7;
    }

    /* --- WORK SESSION BLOCK --- */
    .session-block {
      background: var(--bg-elevated);
      border: 1px solid var(--border-default);
      padding: var(--space-xl);
      margin-bottom: var(--space-lg);
    }

    .session-time {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--node-blue);
      margin-bottom: var(--space-sm);
    }

    .session-title {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 600;
      margin-bottom: var(--space-sm);
    }

    .session-desc {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .session-result {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--node-green);
      margin-top: var(--space-md);
      padding-top: var(--space-md);
      border-top: 1px solid var(--border-subtle);
    }

    /* --- SKPI SECTION --- */
    .skpi-banner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
      align-items: center;
      background: var(--bg-elevated);
      border: 1px solid var(--border-default);
      padding: var(--space-2xl);
    }

    .skpi-text h3 {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 700;
      margin-bottom: var(--space-sm);
    }

    .skpi-text p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .skpi-details {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .skpi-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid var(--border-subtle);
      font-size: 13px;
    }

    .skpi-row:last-child { border-bottom: none; }

    .skpi-key {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }

    .skpi-val {
      color: var(--text-primary);
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
      .an-hero-layout { grid-template-columns: 1fr; }
      .console-mock { order: -1; max-height: 360px; }
      .cap-grid { grid-template-columns: 1fr; }
      .persona-grid { grid-template-columns: 1fr; }
      .skpi-banner { grid-template-columns: 1fr; }
      .an-stats { grid-template-columns: repeat(2, 1fr); }
      .how-track { flex-direction: column; }
      .how-step:not(:last-child) { border-right: 1px solid var(--border-default); border-bottom: none; }
    }

    @media (max-width: 768px) {
      .an-stats { grid-template-columns: 1fr; }
    }
  </style>

  <!-- ============ HERO ============ -->
  <section class="an-hero">
    <div class="container">
      <div class="an-hero-layout">
        <div>
          <div class="an-badge">
            <span class="an-badge-dot"></span>
            Active Development · Proprietary
          </div>
          <h1 class="an-title">
            Annabeth
            <span class="subtitle">AI-Powered Investigation Platform</span>
          </h1>
          <p class="an-tagline">Blue hat intelligence. Ethical by architecture.</p>
          <p class="an-desc">
            Annabeth is a proprietary AI investigation platform that turns natural language
            commands into structured intelligence operations. Built for private investigators,
            red teams, and compliance professionals — it orchestrates automated reconnaissance,
            relationship mapping, evidence chain-of-custody, and adversarial campaign management
            through an agentic AI core with tiered operator controls.
          </p>
          <div class="an-ctas">
            <a href="/services#inquiry" class="btn--blue">Discuss the Platform</a>
            <a href="/#contact" class="btn btn--ghost">Get in Touch</a>
          </div>
        </div>

        <!-- LIVE CONSOLE MOCKUP -->
        <div class="console-mock">
          <div class="console-chrome">
            <span class="dot r"></span>
            <span class="dot y"></span>
            <span class="dot g"></span>
            <div class="tab-bar">
              <span class="tab active">Operation</span>
              <span class="tab">Recon</span>
              <span class="tab">Graph</span>
              <span class="tab">SE</span>
              <span class="tab">Evidence</span>
            </div>
          </div>
          <div class="console-body">
            <div class="console-line"><span class="c-time">08:05:12</span> <span class="c-tool">recon</span> <span class="c-type">MX</span> <span class="c-val">mx1.target.com (email gateway identified)</span> <span class="c-sev-conf">CONFIRMED</span></div>
            <div class="console-line"><span class="c-time">08:05:13</span> <span class="c-tool">recon</span> <span class="c-type">SPF</span> <span class="c-val">soft-fail policy detected</span> <span class="c-sev-high">HIGH</span></div>
            <div class="console-line"><span class="c-time">08:05:13</span> <span class="c-tool">recon</span> <span class="c-type">DMARC</span> <span class="c-val">p=none — monitoring only, no enforcement</span> <span class="c-sev-crit">CRITICAL</span></div>
            <div class="console-line"><span class="c-time">08:05:14</span> <span class="c-tool">recon</span> <span class="c-type">DKIM</span> <span class="c-val">2048-bit key present</span> <span class="c-sev-conf">CONFIRMED</span></div>
            <hr class="console-divider" />
            <div class="console-line"><span class="c-ai">ANNABETH (Analyst):</span></div>
            <div class="console-line"><span class="c-val">BLUF: Email infrastructure vulnerable to domain spoofing.</span></div>
            <div class="console-line"><span class="c-val">DMARC monitoring mode — no enforcement active.</span></div>
            <div class="console-line"><span class="c-val">Soft-fail + no enforcement = spoofed emails deliver.</span></div>
            <div class="console-line"><span class="c-val">Evidence captured → EV-0047-004 (verified, timestamped)</span></div>
            <hr class="console-divider" />
            <div class="console-line"><span class="c-time">08:12:34</span> <span class="c-tool">breach</span> <span class="c-type">EXPOSURE</span> <span class="c-val">j.martinez@ — 2 prior breach events</span> <span class="c-sev-crit">CRITICAL</span></div>
            <div class="console-line"><span class="c-time">08:12:41</span> <span class="c-tool">breach</span> <span class="c-type">EXPOSURE</span> <span class="c-val">d.kim@ — plaintext credential exposure</span> <span class="c-sev-crit">CRITICAL</span></div>
            <div class="console-line"><span class="c-time">08:12:47</span> <span class="c-tool">breach</span> <span class="c-type">EXPOSURE</span> <span class="c-val">r.torres@ — recent credential event</span> <span class="c-sev-high">HIGH</span></div>
            <hr class="console-divider" />
            <div class="console-line"><span class="c-prompt">YOU:</span> <span class="c-val">Deploy SE-001 at 10:15. Set a timer.</span></div>
            <div class="console-line"><span class="c-ai">ANNABETH:</span> <span class="c-val">SE-001 staged. Awaiting approval gate. Deploying at 10:15 EDT.</span></div>
            <hr class="console-divider" />
            <div class="console-line"><span class="c-time">10:23:14</span> <span class="c-sev-crit">⚡ SE-001: r.torres@ OPENED email</span></div>
            <div class="console-line"><span class="c-time">10:23:25</span> <span class="c-sev-crit">⚡ SE-001: r.torres@ CLICKED link</span></div>
            <div class="console-line"><span class="c-time">10:24:06</span> <span class="c-sev-crit">🔴 SE-001: r.torres@ SUBMITTED CREDENTIALS</span></div>
            <div class="console-line"><span class="c-val">   Time-to-credential: 52 seconds from open</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="an-stats animate-in">
        <div class="an-stat">
          <div class="an-stat-num">12<span class="unit">cmds</span></div>
          <div class="an-stat-label">Operator inputs per session</div>
        </div>
        <div class="an-stat">
          <div class="an-stat-num">~140</div>
          <div class="an-stat-label">Autonomous actions executed</div>
        </div>
        <div class="an-stat">
          <div class="an-stat-num">4<span class="unit">hrs</span></div>
          <div class="an-stat-label">Replaces 3–4 days manual work</div>
        </div>
        <div class="an-stat">
          <div class="an-stat-num">72</div>
          <div class="an-stat-label">Findings per engagement</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT IT DOES ============ -->
  <section class="section">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">01</span>
        <h2 class="section-heading">Capabilities</h2>
        <div class="section-rule"></div>
      </div>

      <div class="cap-grid">
        <div class="cap-card animate-in stagger-1">
          <div class="cap-icon">⦿</div>
          <div class="cap-name">Agentic AI Core</div>
          <div class="cap-desc">
            Annabeth runs on a purpose-built agentic AI layer with three adaptive operating
            modes — Analyst, Red Team, and Report. It switches context based on what the
            engagement requires, executing routine intelligence tasks hands-free while
            surfacing sensitive actions to the operator for approval.
          </div>
        </div>

        <div class="cap-card animate-in stagger-2">
          <div class="cap-icon">◇</div>
          <div class="cap-name">Relationship Intelligence Graph</div>
          <div class="cap-desc">
            Every entity discovered — people, domains, infrastructure, exposure events — is
            automatically mapped into a living relationship graph. Cluster analysis identifies
            organizational structures, executive groups, and vendor chains. Bridge nodes reveal
            the highest-leverage attack paths before a human analyst would spot them.
          </div>
        </div>

        <div class="cap-card animate-in stagger-3">
          <div class="cap-icon">△</div>
          <div class="cap-name">Automated Reconnaissance</div>
          <div class="cap-desc">
            Multi-source intelligence collection runs in parallel: infrastructure analysis,
            credential exposure correlation, executive and personnel profiling, vendor chain
            discovery, and open-source enumeration — all fed into the entity graph in real time
            and streamed live to the operator console.
          </div>
        </div>

        <div class="cap-card animate-in stagger-4">
          <div class="cap-icon">□</div>
          <div class="cap-name">Social Engineering Campaign Management</div>
          <div class="cap-desc">
            Design, stage, deploy, and monitor adversarial campaigns with per-recipient behavioral
            tracking — opens, clicks, credential submissions, and time-to-action metrics.
            Every event is automatically captured as evidence. Operator approval gates are
            enforced before any campaign deployment.
          </div>
        </div>

        <div class="cap-card animate-in stagger-5">
          <div class="cap-icon">◎</div>
          <div class="cap-name">Legally Defensible Evidence</div>
          <div class="cap-desc">
            Every finding is automatically preserved with cryptographic integrity verification,
            sequential custody events, and immutable storage. Evidence artifacts are traceable
            back to the raw source, timestamped, and cross-referenced against the operation
            timeline — built to withstand scrutiny in legal and compliance contexts.
          </div>
        </div>

        <div class="cap-card animate-in stagger-6">
          <div class="cap-icon">⬡</div>
          <div class="cap-name">Living Case File</div>
          <div class="cap-desc">
            Every entity, finding, and analysis automatically populates a structured case file
            with full cross-linking. Click any person node and see their role, exposure history,
            graph connections, and every piece of collected evidence — organized and interlinked
            without manual documentation.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">02</span>
        <h2 class="section-heading">How It Works</h2>
        <div class="section-rule"></div>
      </div>

      <div class="how-track animate-in stagger-1">
        <div class="how-step">
          <div class="how-step-num">01</div>
          <div class="how-step-title">Operator Issues a Command</div>
          <div class="how-step-desc">
            Natural language. No syntax, no scripts. "Run recon on this domain." "Who are the
            financial approvers?" "Design a campaign targeting the AP team." Annabeth interprets
            intent and builds the execution plan.
          </div>
        </div>
        <div class="how-step">
          <div class="how-step-num">02</div>
          <div class="how-step-title">Automated Intelligence Collection</div>
          <div class="how-step-desc">
            Annabeth executes dozens of intelligence-gathering actions in parallel — infrastructure
            analysis, exposure correlation, personnel profiling, and more — streaming findings
            live as they surface. The operator watches it work.
          </div>
        </div>
        <div class="how-step">
          <div class="how-step-num">03</div>
