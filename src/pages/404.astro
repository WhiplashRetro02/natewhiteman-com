---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Nate Whiteman">
  <section class="contact-block" style="min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <div class="container" style="text-align: center;">
      <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--accent-muted); margin-bottom: 24px;">
        404 · Node Not Found
      </div>
      <h1 class="contact-heading" style="margin-bottom: 16px;">
        This node doesn't<br>exist in the <span class="italic-accent">graph</span>
      </h1>
      <p class="contact-sub">
        The page you're looking for has been moved, deleted, or never existed.
        Let's get you back on the traversal path.
      </p>
      <a href="/" class="btn btn--primary" style="margin-top: 24px;">
        Return Home
      </a>
    </div>
  </section>
</Base>
