---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Data & Analytics for Real Estate Professionals — Nate Whiteman"
  description="Custom dashboards, deal analysis tools, and CRM systems built specifically for realty groups, brokerages, and house flippers. Fixed-scope, fixed-price."
>

  <!-- ============ HERO ============ -->
  <section class="re-hero">
    <div class="container">
      <div class="re-hero-inner">
        <div class="re-eyebrow">Real Estate · Brokerages · Investors · Flippers</div>
        <h1 class="re-title">
          Stop rebuilding the<br>same spreadsheet<br>for <span class="italic-accent">every deal</span>
        </h1>
        <p class="re-lead">
          Real estate runs on numbers — property values, rehab costs, agent commissions,
          rental yields, closing timelines. Most operators track all of it manually,
          deal by deal, in spreadsheets that don't talk to each other.
          I build the tools that replace that process permanently.
        </p>
        <div class="re-hero-ctas">
          <a href="/services#inquiry" class="btn btn--primary">Talk through your situation &rarr;</a>
          <a href="/samples/property-dashboard" target="_blank" class="btn btn--ghost">See a live sample &nearr;</a>
        </div>
      </div>
    </div>
    <div class="re-hero-rule" aria-hidden="true"></div>
  </section>

  <!-- ============ PERSONAL NOTE ============ -->
  <section class="re-personal">
    <div class="container container--narrow">
      <div class="re-personal-inner">
        <div class="re-personal-glyph" aria-hidden="true">◈</div>
        <blockquote class="re-personal-quote">
          <p>
            When I was searching for my first home, I built my own spreadsheet to track
            every property I looked at — estimated mortgage payments, repair costs, HOA,
            insurance, property tax, total cost of ownership over 5 and 10 years.
            I spent hours getting it right for each property. A well-built tool would
            have cut that to minutes.
          </p>
          <p>
            That's what I build for real estate professionals: the analytical clarity
            I had to construct from scratch, delivered as a system your whole team
            can run without touching a formula.
          </p>
          <footer class="re-personal-attribution">— Nate Whiteman</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ============ WHO I BUILD FOR ============ -->
  <section class="section" id="who">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">01</span>
        <h2 class="section-heading">Who I build for</h2>
        <div class="section-rule"></div>
      </div>

      <div class="re-segments animate-in stagger-1">

        <div class="re-segment re-segment--primary">
          <div class="re-segment-glyph">⬡</div>
          <div class="re-segment-content">
            <div class="re-segment-tag">Primary Focus</div>
            <h3 class="re-segment-title">Realty Groups &amp; Brokerages</h3>
            <p class="re-segment-desc">
              You have a team of agents, a pipeline of deals, and data scattered across
              your CRM, MLS exports, commission sheets, and whoever's inbox closed last
              month's top deal. There's no single place that shows you how the business
              is actually performing.
            </p>
            <ul class="re-segment-pains">
              <li>Agent performance tracked on a whiteboard or in someone's head</li>
              <li>Commission projections rebuilt from scratch every month</li>
              <li>No view of which lead sources are actually converting to closed deals</li>
              <li>Market analysis for clients assembled manually from MLS exports</li>
            </ul>
          </div>
        </div>

        <div class="re-segment">
          <div class="re-segment-glyph">◆</div>
          <div class="re-segment-content">
            <h3 class="re-segment-title">House Flippers &amp; Fix-and-Flip Operators</h3>
            <p class="re-segment-desc">
              Every deal lives in its own spreadsheet. Rehab costs tracked in one file,
              timelines in another, ARV estimates somewhere else. When you're running
              two or three flips at once, there's no clean way to see the whole picture
              without rebuilding it by hand.
            </p>
            <ul class="re-segment-pains">
              <li>Deal underwriting redone from scratch for every acquisition</li>
              <li>Rehab budget vs. actuals tracked in disconnected files</li>
              <li>No historical view of margin by neighborhood, contractor, or project type</li>
              <li>Timeline slippage hard to catch until it's already cost you money</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ WHAT I BUILD ============ -->
  <section class="section re-builds-section" id="builds">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">02</span>
        <h2 class="section-heading">What I build</h2>
        <div class="section-rule"></div>
      </div>

      <div class="re-builds animate-in stagger-1">

        <div class="re-build">
          <div class="re-build-header">
            <span class="re-build-glyph">◈</span>
            <div>
              <div class="re-build-service">Custom Dashboarding</div>
              <h3 class="re-build-title">Brokerage Performance Dashboard</h3>
            </div>
            <span class="re-build-price">from $250</span>
          </div>
          <p class="re-build-desc">
            A single view of your whole operation — agent activity, pipeline stage,
            closed volume, commission earned, and market-level trends — connected directly
            to your existing data and refreshed automatically. No more asking your top
            agent how many deals they have in flight.
          </p>
          <ul class="re-build-bullets">
            <li>Agent-level and team-level performance views</li>
            <li>Pipeline stage tracking from lead to close</li>
            <li>Commission projections and YTD actuals</li>
            <li>Lead source conversion rates</li>
          </ul>
          <a href="/services#inquiry" class="btn btn--ghost re-build-cta">Start this project &rarr;</a>
        </div>

        <div class="re-build">
          <div class="re-build-header">
            <span class="re-build-glyph">◆</span>
            <div>
              <div class="re-build-service">Deal Analysis Tools</div>
              <h3 class="re-build-title">Flip Deal Analyzer &amp; Portfolio Tracker</h3>
            </div>
            <span class="re-build-price">from $500</span>
          </div>
          <p class="re-build-desc">
            Stop building a new spreadsheet for every deal. A standardized underwriting
            tool that calculates your all-in cost, projected ARV, carrying costs,
            and expected margin — and stores every deal in a searchable portfolio so
            you can see which neighborhoods and project types are actually performing.
          </p>
          <ul class="re-build-bullets">
            <li>Standardized deal underwriting: purchase, rehab, carrying costs, ARV</li>
            <li>Active project tracker: budget vs. actuals, milestone status</li>
            <li>Portfolio-level view: margin by deal, by neighborhood, by contractor</li>
            <li>Historical deal library — learn from your own data over time</li>
          </ul>
          <a href="/services#inquiry" class="btn btn--ghost re-build-cta">Start this project &rarr;</a>
        </div>

        <div class="re-build">
          <div class="re-build-header">
            <span class="re-build-glyph">⬢</span>
            <div>
              <div class="re-build-service">Custom CRM</div>
              <h3 class="re-build-title">Agent Pipeline &amp; Client CRM</h3>
            </div>
            <span class="re-build-price">from $100</span>
          </div>
          <p class="re-build-desc">
            A CRM built around how real estate actually works — not a generic sales
            funnel. Track buyer and seller clients through their full lifecycle,
            automate follow-up reminders, and sync with your calendar so nothing
            falls through the cracks during a busy closing season.
          </p>
          <ul class="re-build-bullets">
            <li>Buyer and seller pipelines with stage-specific workflows</li>
            <li>Automated follow-up reminders and task triggers</li>
            <li>Calendar and email integration</li>
            <li>Referral source tracking per closed deal</li>
          </ul>
          <a href="/services#inquiry" class="btn btn--ghost re-build-cta">Start this project &rarr;</a>
        </div>

        <div class="re-build">
          <div class="re-build-header">
            <span class="re-build-glyph">◇</span>
            <div>
              <div class="re-build-service">Data Analytics</div>
              <h3 class="re-build-title">Market &amp; Pricing Analysis</h3>
            </div>
            <span class="re-build-price">from $150</span>
          </div>
          <p class="re-build-desc">
            One-time or recurring analysis of market conditions, pricing trends,
            or your own deal history — delivered as a clear report your team can act on.
            Useful for pricing presentations, investment committee decks, or just
            understanding which markets you should be in next.
          </p>
          <ul class="re-build-bullets">
            <li>Neighborhood-level pricing trend analysis</li>
            <li>Comparable sales analysis beyond what the MLS shows</li>
            <li>Your own deal history — where you made money and where you didn't</li>
            <li>Investment committee-ready report format</li>
          </ul>
          <a href="/services#inquiry" class="btn btn--ghost re-build-cta">Start this project &rarr;</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ PORTFOLIO SAMPLE ============ -->
  <section class="re-sample-section" id="sample">
    <div class="container">
      <div class="re-sample-inner">
        <div class="re-sample-text">
          <div class="re-sample-eyebrow">Live Portfolio Sample</div>
          <h2 class="re-sample-title">See a real deal analyzer, fully built</h2>
          <p class="re-sample-desc">
            This interactive dashboard was built to analyze a duplex acquisition —
            cash flow projections, inspection health scoring across six system categories,
            a full repair cost matrix, 30-year amortization and equity modeling,
            and scenario planning for different appreciation rates.
          </p>
          <p class="re-sample-desc">
            This is the level of depth a typical engagement produces.
            Every section is driven by real inputs, real math, and real decisions.
          </p>
          <div class="re-sample-tabs">
            <span class="re-sample-tab">Financial Projections</span>
            <span class="re-sample-tab">Inspection Scoring</span>
            <span class="re-sample-tab">Repair Cost Matrix</span>
            <span class="re-sample-tab">Equity Modeling</span>
            <span class="re-sample-tab">Scenario Planning</span>
          </div>
          <a href="/samples/property-dashboard" target="_blank" class="btn btn--primary">Open the live dashboard &nearr;</a>
        </div>
        <div class="re-sample-preview" aria-hidden="true">
          <div class="re-sample-chrome">
            <div class="re-sample-chrome-bar">
              <span class="re-chrome-dot"></span>
              <span class="re-chrome-dot"></span>
              <span class="re-chrome-dot"></span>
              <span class="re-chrome-url">natewhiteman.com/samples/property-dashboard</span>
            </div>
            <div class="re-sample-screen">
              <div class="re-screen-kpis">
                <div class="re-kpi"><span class="re-kpi-val">B−</span><span class="re-kpi-lbl">Overall Grade</span></div>
                <div class="re-kpi"><span class="re-kpi-val re-kpi-val--g">$1,150</span><span class="re-kpi-lbl">Monthly Rent</span></div>
                <div class="re-kpi"><span class="re-kpi-val re-kpi-val--a">71%</span><span class="re-kpi-lbl">Confidence</span></div>
                <div class="re-kpi"><span class="re-kpi-val">$319K</span><span class="re-kpi-lbl">Purchase Price</span></div>
              </div>
              <div class="re-screen-bars">
                <div class="re-screen-bar-label">System Health Scores</div>
                {[
                  { label: "Structure", val: 78 },
                  { label: "Electrical", val: 64 },
                  { label: "Plumbing", val: 63 },
                  { label: "HVAC", val: 66 },
                  { label: "Interior", val: 67 },
                ].map(b => (
                  <div class="re-screen-bar-row">
                    <span class="re-screen-bar-name">{b.label}</span>
                    <div class="re-screen-bar-track">
                      <div class="re-screen-bar-fill" style={`width: ${b.val}%`}></div>
                    </div>
                    <span class="re-screen-bar-val">{b.val}</span>
                  </div>
                ))}
              </div>
              <div class="re-screen-footer">7 tabs · Financials · Units · Inspection · Repairs · Scenarios · Equity</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TOOLS WE CONNECT ============ -->
  <section class="section re-tools-section" id="tools">
    <div class="container">
      <div class="section-label animate-in">
        <span class="section-num">03</span>
        <h2 class="section-heading">What I connect it to</h2>
        <div class="section-rule"></div>
      </div>
      <p class="re-tools-intro animate-in">
        I build on top of the tools you already use — no ripping and replacing your stack.
      </p>
      <div class="re-tools animate-in stagger-1">
        {[
          { name: "AppFolio",   desc: "Property management · lease and payment data" },
          { name: "Excel / Google Sheets", desc: "Existing models and deal trackers" },
          { name: "QuickBooks", desc: "Rehab cost tracking and expense categorization" },
          { name: "MLS Exports", desc: "Comp data and market trend analysis" },
          { name: "PropStream", desc: "Deal sourcing and property history" },
          { name: "Google Calendar / Outlook", desc: "Closing timelines and follow-up automation" },
          { name: "Buildium",   desc: "Tenant records and maintenance history" },
          { name: "Custom data", desc: "Anything in a spreadsheet, CSV, or database" },
        ].map(t => (
          <div class="re-tool">
            <div class="re-tool-name">{t.name}</div>
            <div class="re-tool-desc">{t.desc}</div>
          </div>
        ))}
      </div>
      <p class="re-tools-note">
        Don't see your tool? <a href="/services#inquiry">Send me a message</a> — if it exports data, I can almost certainly connect to it.
      </p>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="re-cta-section">
    <div class="container container--narrow">
      <div class="re-cta-inner">
        <div class="re-cta-text">
          <h2 class="re-cta-title">Ready to stop living in spreadsheets?</h2>
          <p class="re-cta-desc">
            Tell me what you're working with — tools, team size, the problem you're
            trying to solve. First conversation is free, and I'll tell you plainly
            whether what you need is something I can build.
          </p>
        </div>
        <div class="re-cta-actions">
          <a href="/services#inquiry" class="btn btn--primary">Start a conversation &rarr;</a>
          <a href="/services" class="btn btn--ghost">See all services &darr;</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ---- HERO ---- */
  .re-hero {
    padding: calc(var(--space-4xl) + 60px) 0 var(--space-3xl);
    position: relative;
  }

  .re-hero-inner { max-width: 760px; }

  .re-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-muted);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .re-eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .re-title {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 76px);
    font-weight: 800;
    line-height: 0.96;
    letter-spacing: -3px;
    margin-bottom: var(--space-xl);
  }

  .re-lead {
    font-size: 17px;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: var(--space-xl);
  }

  .re-hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .re-hero-rule {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-default) 30%, var(--border-default) 70%, transparent);
  }

  /* ---- PERSONAL NOTE ---- */
  .re-personal {
    padding: var(--space-3xl) 0;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-default);
  }

  .re-personal-inner {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
  }

  .re-personal-glyph {
    font-size: 32px;
    color: var(--accent-muted);
    flex-shrink: 0;
    margin-top: 4px;
    opacity: 0.6;
  }

  .re-personal-quote {
    border-left: 2px solid var(--border-accent);
    padding-left: var(--space-xl);
    margin: 0;
  }

  .re-personal-quote p {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.85;
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  .re-personal-quote p:last-of-type { margin-bottom: var(--space-lg); }

  .re-personal-attribution {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent-muted);
    letter-spacing: 1.5px;
  }

  /* ---- SEGMENTS ---- */
  .re-segments {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border-default);
    border: 1px solid var(--border-default);
  }

  .re-segment {
    background: var(--bg-primary);
    padding: var(--space-xl);
    display: flex;
    gap: var(--space-lg);
  }

  .re-segment--primary {
    background: var(--bg-elevated);
    border-top: 3px solid var(--accent);
  }

  .re-segment-glyph {
    font-size: 28px;
    color: var(--accent-muted);
    flex-shrink: 0;
    opacity: 0.5;
    margin-top: 2px;
    line-height: 1;
  }

  .re-segment-tag {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--border-accent);
    padding: 2px 8px;
    display: inline-block;
    margin-bottom: 8px;
  }

  .re-segment-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    letter-spacing: -0.3px;
  }

  .re-segment-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }

  .re-segment-pains {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .re-segment-pains li {
    font-size: 12px;
    color: var(--text-tertiary);
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.6;
  }

  .re-segment-pains li::before {
    content: '—';
    color: var(--accent-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ---- WHAT I BUILD ---- */
  .re-builds-section { background: var(--bg-elevated); border-top: 1px solid var(--border-default); }

  .re-builds {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border-default);
    border: 1px solid var(--border-default);
  }

  .re-build {
    background: var(--bg-primary);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .re-build:hover { background: var(--bg-elevated); }

  .re-build-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .re-build-glyph {
    font-size: 24px;
    color: var(--accent-muted);
    flex-shrink: 0;
    opacity: 0.5;
    line-height: 1;
    margin-top: 2px;
  }

  .re-build-service {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent-muted);
    margin-bottom: 4px;
  }

  .re-build-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.2px;
    line-height: 1.2;
  }

  .re-build-price {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-left: auto;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .re-build-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .re-build-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
  }

  .re-build-bullets li {
    font-size: 12px;
    color: var(--text-tertiary);
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.55;
  }

  .re-build-bullets li::before {
    content: '→';
    color: var(--accent-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .re-build-cta { align-self: flex-start; margin-top: var(--space-sm); }

  /* ---- PORTFOLIO SAMPLE ---- */
  .re-sample-section {
    padding: var(--space-4xl) 0;
    border-top: 1px solid var(--border-default);
  }

  .re-sample-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .re-sample-eyebrow {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent-muted);
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .re-sample-eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--accent-muted);
  }

  .re-sample-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .re-sample-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .re-sample-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--space-xl);
  }

  .re-sample-tab {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 1px;
    color: var(--text-tertiary);
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    padding: 3px 10px;
  }

  /* Browser chrome mockup */
  .re-sample-chrome {
    border: 1px solid var(--border-default);
    background: var(--bg-primary);
    overflow: hidden;
    box-shadow: 0 24px 80px #00000066;
  }

  .re-sample-chrome-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-default);
  }

  .re-chrome-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-default);
  }

  .re-chrome-url {
    font-family: var(--font-mono);
    font-size: 8px;
