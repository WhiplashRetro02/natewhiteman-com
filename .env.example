# ── Resend (email notifications for contact form) ──────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# The email address where inquiries should be delivered
RESEND_TO_EMAIL=nate@natewhiteman.com

# The from address — must be from a verified domain in Resend
# Verify natewhiteman.com at: https://resend.com/domains
# Until verified, use: onboarding@resend.dev (Resend's shared sender, no setup needed)
RESEND_FROM_EMAIL=inquiries@natewhiteman.com

# ── Cloudflare D1 (identity pixel) ─────────────────────────────────────────
# D1 is configured via wrangler.toml + Cloudflare Pages dashboard bindings.
# No env var needed here — the DB binding is injected by the Cloudflare runtime.

# ── Plausible Analytics (self-hosted) ────────────────────────────────────────
# Your self-hosted Plausible instance URL — no trailing slash.
# Local dev:  http://localhost:8000
# Production: https://analytics.natewhiteman.com  (once Cloudflare Tunnel is set up)
# Leave blank to disable analytics script (e.g. during local Astro dev without Docker running)
PUBLIC_PLAUSIBLE_URL=
