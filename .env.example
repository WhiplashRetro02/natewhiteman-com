# GitHub API — used by the contact form to write lead files into the repo
# Create a fine-grained personal access token at:
#   https://github.com/settings/tokens?type=beta
# Grant: Contents (Read & Write) on the target repository
GITHUB_TOKEN=ghp_your_token_here

# The GitHub repo in owner/repo format (e.g. natewhiteman/natewhiteman-com)
GITHUB_REPO=your-github-username/natewhiteman-com

# Resend API — sends email notification for each form submission
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# The email address where inquiries should be delivered
RESEND_TO_EMAIL=nate@natewhiteman.com

# The from address — must be from a verified domain in Resend
# Verify natewhiteman.com at: https://resend.com/domains
RESEND_FROM_EMAIL=inquiries@natewhiteman.com
